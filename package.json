{
  "name": "quizzify",
  "version": "1.0.0",
  "description": "Turn any GitHub repository into an interactive quiz to test your knowledge and learn more about the codebase",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "echo \"No tests specified yet\" && exit 0"
  },
  "keywords": [
    "quiz",
    "github",
    "learning",
    "interactive",
    "education",
    "coding",
    "nextjs",
    "typescript"
  ],
  "author": "Quizzify Team",
  "license": "MIT",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "15.3.4"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "@eslint/eslintrc": "^3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
